<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.smarttask.controller.LoginController"
      spacing="20" alignment="CENTER"
      style="-fx-padding: 50; -fx-background-color: #2c3e50;"
      prefWidth="400" prefHeight="500">

    <Label text="🔐 SmartTask"
           style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: white;"/>
    <Label text="Connectez-vous pour continuer"
           style="-fx-font-size: 13px; -fx-text-fill: #bdc3c7;"/>

    <VBox spacing="10" style="-fx-background-color: white; -fx-padding: 30; -fx-background-radius: 10;">

        <!-- Username -->
        <Label text="Nom d'utilisateur"/>
        <TextField fx:id="champUsername" promptText="Entrez votre nom d'utilisateur"/>

        <!-- Password -->
        <Label text="Mot de passe"/>
        <PasswordField fx:id="champPassword" promptText="Entrez votre mot de passe"/>

        <!-- Message erreur -->
        <Label fx:id="labelErreur" text=""
               style="-fx-text-fill: #e74c3c; -fx-font-size: 12px;"/>

        <!-- Boutons -->
        <Button text="🔑 Se connecter" onAction="#seConnecter"
                maxWidth="Infinity"
                style="-fx-background-color: #3498db; -fx-text-fill: white;
                       -fx-font-size: 14px; -fx-padding: 10; -fx-background-radius: 6;"/>

        <Button text="📝 S'inscrire" onAction="#sInscrire"
                maxWidth="Infinity"
                style="-fx-background-color: #2ecc71; -fx-text-fill: white;
                       -fx-font-size: 14px; -fx-padding: 10; -fx-background-radius: 6;"/>
    </VBox>

</VBox>