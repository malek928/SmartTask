<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.smarttask.controller.HistoryController"
      spacing="15"
      style="-fx-padding: 20; -fx-background-color: #f5f6fa;"
      prefWidth="900" prefHeight="600">

    <Label text="📦 Historique des tâches archivées"
           style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>

    <HBox spacing="10">
        <Button text="🔄 Restaurer" onAction="#restaurerTache"
                style="-fx-background-color: #2ecc71; -fx-text-fill: white;
                       -fx-padding: 8 16; -fx-background-radius: 6;"/>
        <Button text="🗑️ Supprimer définitivement" onAction="#supprimerDefinitivement"
                style="-fx-background-color: #e74c3c; -fx-text-fill: white;
                       -fx-padding: 8 16; -fx-background-radius: 6;"/>
    </HBox>

    <TableView fx:id="tableArchives" prefHeight="450">
        <columns>
            <TableColumn fx:id="colTitre" text="Titre" prefWidth="200"/>
            <TableColumn fx:id="colDescription" text="Description" prefWidth="250"/>
            <TableColumn fx:id="colPriorite" text="Priorité" prefWidth="100"/>
            <TableColumn fx:id="colStatut" text="Statut" prefWidth="120"/>
            <TableColumn fx:id="colDeadline" text="Deadline" prefWidth="110"/>
        </columns>
    </TableView>

    <Label fx:id="labelStatut" text=""/>

</VBox>